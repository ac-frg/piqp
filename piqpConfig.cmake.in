@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(Eigen3 REQUIRED NO_MODULE)
if (Eigen3_VERSION VERSION_LESS "3.3")
    message(FATAL_ERROR "Eigen3 >= 3.3 required, found ${Eigen3_VERSION}")
endif ()
if (@BUILD_WITH_BLASFEO@)
    find_dependency(blasfeo REQUIRED)
endif()
if (@PIQP_WITH_OPENMP_TARGET@)
    find_dependency(OpenMP REQUIRED COMPONENTS CXX)
endif()
if (@BUILD_WITH_TRACY@)
    find_dependency(Tracy CONFIG REQUIRED)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@Targets.cmake")

check_required_components(@PROJECT_NAME@)
